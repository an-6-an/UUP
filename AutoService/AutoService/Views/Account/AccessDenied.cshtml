@{
    ViewData["Title"] = "Доступ запрещен";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-lg">
                <div class="card-header bg-danger text-white text-center py-4">
                    <h3 class="mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>Доступ запрещен
                    </h3>
                </div>
                <div class="card-body text-center p-5">
                    <i class="bi bi-shield-lock text-danger" style="font-size: 5rem;"></i>

                    <h4 class="mt-4">У вас нет прав для доступа к этой странице</h4>

                    <p class="text-muted mb-4">
                        Если вы считаете, что это ошибка, обратитесь к администратору.
                    </p>

                    <div class="d-grid gap-2">
                        <a asp-action="Index" asp-controller="Requests" class="btn btn-primary">
                            <i class="bi bi-house me-2"></i>На главную
                        </a>
                        <a asp-action="Login" asp-controller="Account" class="btn btn-outline-secondary">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Войти как другой пользователь
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>