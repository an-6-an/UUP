@{
    ViewData["Title"] = "Вход";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Вход — АвтоТранс</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); min-height: 100vh; display: flex; align-items: center; }
        .login-card { border-radius: 16px; border: none; box-shadow: 0 20px 60px rgba(0,0,0,.4); }
        .login-card .card-header { background: #0d6efd; border-radius: 16px 16px 0 0; padding: 2rem; text-align: center; }
        .form-control { border-radius: 10px; padding: .7rem 1rem; }
        .btn-login { border-radius: 10px; padding: .75rem; font-size: 1rem; font-weight: 600; }
    </style>
</head>
<body>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card login-card">
                <div class="card-header text-white">
                    <h2 class="mb-1"><i class="bi bi-wrench-adjustable-circle"></i> АвтоТранс</h2>
                    <p class="mb-0 opacity-75">Система учёта заявок на ремонт</p>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }
                    <form method="post" asp-action="Login">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Логин</label>
                            <input type="text" name="login" class="form-control" placeholder="Введите логин" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Пароль</label>
                            <input type="password" name="password" class="form-control" placeholder="Введите пароль" required />
                        </div>
                        <button type="submit" class="btn btn-primary btn-login w-100">
                            <i class="bi bi-box-arrow-in-right"></i> Войти
                        </button>
                    </form>
                    <hr class="my-3" />
                    <div class="text-center">
                        <span class="text-muted small">Нет аккаунта?</span>
                        <a href="/Account/Register" class="ms-1 small fw-semibold">Зарегистрироваться</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
</body>
</html>
