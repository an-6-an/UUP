@{
    ViewData["Title"] = "Добро пожаловать";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card shadow-lg border-0 rounded-lg fade-in">
                <div class="card-header bg-primary text-white py-4">
                    <h1 class="display-4 mb-0">
                        <i class="bi bi-gear-wide-connected me-3"></i>Автосервис
                    </h1>
                </div>
                <div class="card-body p-5">
                    <i class="bi bi-tools text-primary" style="font-size: 5rem;"></i>

                    <h2 class="mt-4 mb-3">Система управления заявками на ремонт</h2>

                    <p class="lead text-muted mb-4">
                        Добро пожаловать в систему автоматизации автосервиса.
                        Здесь вы можете создавать и отслеживать заявки на ремонт автомобилей.
                    </p>

                    <div class="row mt-5">
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-primary">
                                <div class="card-body">
                                    <i class="bi bi-plus-circle text-primary" style="font-size: 2rem;"></i>
                                    <h5 class="mt-2">Создание заявок</h5>
                                    <p class="text-muted">Быстрое создание новых заявок на ремонт</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-success">
                                <div class="card-body">
                                    <i class="bi bi-clock-history text-success" style="font-size: 2rem;"></i>
                                    <h5 class="mt-2">Отслеживание</h5>
                                    <p class="text-muted">Контроль статуса выполнения работ</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-info">
                                <div class="card-body">
                                    <i class="bi bi-bar-chart text-info" style="font-size: 2rem;"></i>
                                    <h5 class="mt-2">Статистика</h5>
                                    <p class="text-muted">Анализ эффективности работы</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5">
                        @if (!User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg me-2">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Войти
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-lg">
                                <i class="bi bi-person-plus me-2"></i>Регистрация
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Requests" asp-action="Index" class="btn btn-primary btn-lg">
                                <i class="bi bi-list-task me-2"></i>Перейти к заявкам
                            </a>
                        }
                    </div>
                </div>
                <div class="card-footer text-muted bg-light py-3">
                    <small>Демоэкзамен 09.02.07 - Программирование</small>
                </div>
            </div>
        </div>
    </div>
</div>