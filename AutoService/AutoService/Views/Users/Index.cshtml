@model IEnumerable<AutoService.Models.User>
@{
    ViewData["Title"] = "Пользователи";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-people text-primary"></i> Пользователи системы</h3>
    <a href="/Users/Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Добавить</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>ФИО</th>
                    <th>Телефон</th>
                    <th>Логин</th>
                    <th>Роль</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.UserID</td>
                        <td>@u.FIO</td>
                        <td>@u.Phone</td>
                        <td><code>@u.Login</code></td>
                        <td>
                            @{
                                var roleBg = u.Type switch
                                {
                                    "Менеджер" => "bg-danger",
                                    "Оператор" => "bg-primary",
                                    "Автомеханик" => "bg-warning text-dark",
                                    "Заказчик" => "bg-success",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @roleBg">@u.Type</span>
                        </td>
                        <td>
                            <a href="/Users/Edit/@u.UserID" class="btn btn-sm btn-outline-secondary btn-action"><i class="bi bi-pencil"></i></a>
                            <form method="post" action="/Users/Delete/@u.UserID" style="display:inline" onsubmit="return confirm('Удалить пользователя @u.FIO?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger btn-action"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
