@model AutoService.Models.User
@{
    ViewData["Title"] = "Редактирование пользователя";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-person-gear text-primary"></i> Редактирование пользователя</h3>
    <a href="/Users" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Назад</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="Edit">
            <input type="hidden" name="UserID" value="@Model.UserID" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">ФИО</label>
                    <input type="text" name="FIO" value="@Model.FIO" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Телефон</label>
                    <input type="text" name="Phone" value="@Model.Phone" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Логин</label>
                    <input type="text" name="Login" value="@Model.Login" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Пароль</label>
                    <input type="text" name="Password" value="@Model.Password" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Роль</label>
                    <select name="Type" class="form-select" required>
                        <option value="Менеджер" selected="@(Model.Type == "Менеджер")">Менеджер</option>
                        <option value="Оператор" selected="@(Model.Type == "Оператор")">Оператор</option>
                        <option value="Автомеханик" selected="@(Model.Type == "Автомеханик")">Автомеханик</option>
                        <option value="Заказчик" selected="@(Model.Type == "Заказчик")">Заказчик</option>
                    </select>
                </div>
                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg"></i> Сохранить</button>
                </div>
            </div>
        </form>
    </div>
</div>