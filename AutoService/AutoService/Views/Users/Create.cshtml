@model AutoService.Models.User
@{
    ViewData["Title"] = "Добавить пользователя";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-person-plus text-primary"></i> Новый пользователь</h3>
    <a href="/Users" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Назад</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="Create">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@e.ErrorMessage</div>
                    }
                </div>
            }
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">ФИО</label>
                    <input type="text" name="FIO" value="@Model?.FIO" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Телефон</label>
                    <input type="text" name="Phone" value="@Model?.Phone" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Логин</label>
                    <input type="text" name="Login" value="@Model?.Login" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Пароль</label>
                    <input type="text" name="Password" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Роль</label>
                    <select name="Type" class="form-select" required>
                        @foreach (var r in new[] { "Менеджер", "Оператор", "Автомеханик", "Заказчик" })
                        {
                            <option value="@r">@r</option>
                        }
                    </select>
                </div>
                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg"></i> Создать</button>
                </div>
            </div>
        </form>
    </div>
</div>
