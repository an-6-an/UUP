@model AutoService.Models.Request
@{
    ViewData["Title"] = $"Редактирование заявки #{Model.RequestID}";
    var userType = ViewBag.UserType as string;
    var mechanics = ViewBag.Mechanics as List<AutoService.Models.User> ?? new();
    var clients = ViewBag.Clients as List<AutoService.Models.User> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-pencil text-primary"></i> Редактирование заявки #@Model.RequestID</h3>
    <a href="/Requests/Details/@Model.RequestID" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Назад</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post">
            <input type="hidden" name="RequestID" value="@Model.RequestID" />
            <div class="row g-3">

                @if (userType == "Менеджер" || userType == "Оператор" || userType == "Заказчик")
                {
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Вид автомобиля</label>
                        <select name="CarType" class="form-select">
                            <option value="Легковая" selected="@(Model.CarType == "Легковая")">Легковая</option>
                            <option value="Грузовая" selected="@(Model.CarType == "Грузовая")">Грузовая</option>
                            <option value="Мотоцикл" selected="@(Model.CarType == "Мотоцикл")">Мотоцикл</option>
                            <option value="Автобус" selected="@(Model.CarType == "Автобус")">Автобус</option>
                            <option value="Спецтехника" selected="@(Model.CarType == "Спецтехника")">Спецтехника</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Модель автомобиля</label>
                        <input type="text" name="CarModel" value="@Model.CarModel" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Описание проблемы</label>
                        <textarea name="ProblemDescription" class="form-control" rows="3">@Model.ProblemDescription</textarea>
                    </div>
                }

                @if (userType == "Менеджер" || userType == "Оператор")
                {
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Клиент</label>
                        <select name="ClientID" class="form-select">
                            @foreach (var c in clients)
                            {
                                if (Model.ClientID == c.UserID)
                                {
                                    <option value="@c.UserID" selected="selected">@c.FIO</option>
                                }
                                else
                                {
                                    <option value="@c.UserID">@c.FIO</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Механик</label>
                        <select name="MasterID" class="form-select">
                            <option value="">Не назначен</option>
                            @foreach (var m in mechanics)
                            {
                                if (Model.MasterID == m.UserID)
                                {
                                    <option value="@m.UserID" selected="selected">@m.FIO</option>
                                }
                                else
                                {
                                    <option value="@m.UserID">@m.FIO</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Статус</label>
                        <select name="RequestStatus" class="form-select">
                            <option value="Новая заявка" selected="@(Model.RequestStatus == "Новая заявка")">Новая заявка</option>
                            <option value="В процессе ремонта" selected="@(Model.RequestStatus == "В процессе ремонта")">В процессе ремонта</option>
                            <option value="Ожидание автозапчастей" selected="@(Model.RequestStatus == "Ожидание автозапчастей")">Ожидание автозапчастей</option>
                            <option value="Готова к выдаче" selected="@(Model.RequestStatus == "Готова к выдаче")">Готова к выдаче</option>
                            <option value="Завершена" selected="@(Model.RequestStatus == "Завершена")">Завершена</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Запчасти / материалы</label>
                        <input type="text" name="RepairParts" value="@Model.RepairParts" class="form-control" placeholder="Список запчастей..." />
                    </div>
                }

                @if (userType == "Автомеханик")
                {
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Статус</label>
                        <select name="RequestStatus" class="form-select">
                            <option value="Новая заявка" selected="@(Model.RequestStatus == "Новая заявка")">Новая заявка</option>
                            <option value="В процессе ремонта" selected="@(Model.RequestStatus == "В процессе ремонта")">В процессе ремонта</option>
                            <option value="Ожидание автозапчастей" selected="@(Model.RequestStatus == "Ожидание автозапчастей")">Ожидание автозапчастей</option>
                            <option value="Готова к выдаче" selected="@(Model.RequestStatus == "Готова к выдаче")">Готова к выдаче</option>
                            <option value="Завершена" selected="@(Model.RequestStatus == "Завершена")">Завершена</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Запчасти / материалы</label>
                        <input type="text" name="RepairParts" value="@Model.RepairParts" class="form-control" placeholder="Список запчастей..." />
                    </div>
                }

                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg"></i> Сохранить изменения</button>
                </div>
            </div>
        </form>
    </div>
</div>
