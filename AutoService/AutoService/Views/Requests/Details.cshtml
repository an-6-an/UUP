@model AutoService.Models.Request
@{
    ViewData["Title"] = $"Заявка #{Model.RequestID}";
    var userType = ViewBag.UserType as string;
    var userId = (int)ViewBag.UserID;
    var mechanics = ViewBag.Mechanics as List<AutoService.Models.User> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-file-text text-primary"></i> Заявка #@Model.RequestID</h3>
    <a href="/Requests" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Назад</a>
</div>

<div class="row g-4">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header fw-semibold"><i class="bi bi-car-front"></i> Информация об автомобиле</div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr><th width="40%">Вид авто</th><td>@Model.CarType</td></tr>
                    <tr><th>Модель</th><td>@Model.CarModel</td></tr>
                    <tr><th>Описание проблемы</th><td>@Model.ProblemDescription</td></tr>
                    <tr><th>Запчасти</th><td>@(string.IsNullOrEmpty(Model.RepairParts) ? "—" : Model.RepairParts)</td></tr>
                </table>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header fw-semibold"><i class="bi bi-person"></i> Клиент и механик</div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr><th width="40%">Клиент</th><td>@Model.Client?.FIO <br /><small class="text-muted">@Model.Client?.Phone</small></td></tr>
                    <tr><th>Механик</th><td>@(Model.Master?.FIO ?? "Не назначен")</td></tr>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card">
            <div class="card-header fw-semibold"><i class="bi bi-info-circle"></i> Статус заявки</div>
            <div class="card-body">
                @{
                    var (bg, icon) = Model.RequestStatus switch
                    {
                        "Новая заявка" => ("bg-secondary", "bi-plus-circle"),
                        "В процессе ремонта" => ("bg-warning text-dark", "bi-gear"),
                        "Ожидание автозапчастей" => ("bg-info text-dark", "bi-hourglass"),
                        "Готова к выдаче" => ("bg-success", "bi-check-circle"),
                        "Завершена" => ("bg-dark", "bi-check2-all"),
                        _ => ("bg-secondary", "bi-question")
                    };
                }
                <span class="badge @bg badge-status fs-6 mb-3"><i class="bi @icon"></i> @Model.RequestStatus</span>
                <table class="table table-borderless mb-0">
                    <tr><th width="50%">Дата создания</th><td>@Model.StartDate.ToString("dd.MM.yyyy")</td></tr>
                    <tr><th>Дата завершения</th><td>@(Model.CompletionDate?.ToString("dd.MM.yyyy") ?? "—")</td></tr>
                </table>

                @if (userType == "Менеджер" || userType == "Оператор" || userType == "Автомеханик")
                {
                    <a href="/Requests/Edit/@Model.RequestID" class="btn btn-primary mt-3 w-100"><i class="bi bi-pencil"></i> Редактировать заявку</a>
                }
            </div>
        </div>
    </div>
</div>

<!-- Комментарии -->
<div class="card mt-4">
    <div class="card-header fw-semibold"><i class="bi bi-chat-dots"></i> Комментарии механиков</div>
    <div class="card-body">
        @if (!Model.Comments.Any())
        {
            <p class="text-muted">Комментариев пока нет.</p>
        }
        else
        {
            foreach (var c in Model.Comments)
            {
                <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-3">
                    <div>
                        <strong class="text-primary"><i class="bi bi-person-circle"></i> @c.Master?.FIO</strong>
                        <p class="mb-0 mt-1">@c.Message</p>
                    </div>
                    @if (userType == "Менеджер")
                    {
                        <form method="post" action="/Requests/DeleteComment" onsubmit="return confirm('Удалить комментарий?')">
                            <input type="hidden" name="commentId" value="@c.CommentID" />
                            <input type="hidden" name="requestId" value="@Model.RequestID" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    }
                </div>
            }
        }

        @if (userType == "Автомеханик" || userType == "Менеджер")
        {
            <form method="post" action="/Requests/AddComment" class="mt-3">
                <input type="hidden" name="requestId" value="@Model.RequestID" />
                <div class="input-group">
                    <textarea name="message" class="form-control" rows="2" placeholder="Добавить комментарий..." required></textarea>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Отправить</button>
                </div>
            </form>
        }
    </div>
</div>
