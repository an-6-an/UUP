@model IEnumerable<AutoService.Models.Request>
@{
    ViewData["Title"] = "Заявки";
    var userType = ViewBag.UserType as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-clipboard-check text-primary"></i> Заявки на ремонт</h3>
    @if (userType == "Заказчик" || userType == "Оператор" || userType == "Менеджер")
    {
        <a href="/Requests/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Новая заявка</a>
    }
</div>

<!-- Фильтры -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold">Поиск</label>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Номер заявки, модель авто, ФИО клиента..." />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Статус</label>
                <select name="status" class="form-select">
                    <option value="">Все статусы</option>
                    <option value="Новая заявка" selected="@(ViewBag.Status == "Новая заявка")">Новая заявка</option>
                    <option value="В процессе ремонта" selected="@(ViewBag.Status == "В процессе ремонта")">В процессе ремонта</option>
                    <option value="Ожидание автозапчастей" selected="@(ViewBag.Status == "Ожидание автозапчастей")">Ожидание автозапчастей</option>
                    <option value="Готова к выдаче" selected="@(ViewBag.Status == "Готова к выдаче")">Готова к выдаче</option>
                    <option value="Завершена" selected="@(ViewBag.Status == "Завершена")">Завершена</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i> Найти</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Дата</th>
                        <th>Автомобиль</th>
                        <th>Проблема</th>
                        <th>Клиент</th>
                        <th>Механик</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-bold">@r.RequestID</td>
                            <td>@r.StartDate.ToString("dd.MM.yyyy")</td>
                            <td>@r.CarType<br /><small class="text-muted">@r.CarModel</small></td>
                            <td><small>@r.ProblemDescription</small></td>
                            <td><small>@r.Client?.FIO</small></td>
                            <td><small>@(r.Master?.FIO ?? "—")</small></td>
                            <td>
                                @{
                                    var (bg, icon) = r.RequestStatus switch
                                    {
                                        "Новая заявка" => ("bg-secondary", "bi-plus-circle"),
                                        "В процессе ремонта" => ("bg-warning text-dark", "bi-gear"),
                                        "Ожидание автозапчастей" => ("bg-info text-dark", "bi-hourglass"),
                                        "Готова к выдаче" => ("bg-success", "bi-check-circle"),
                                        "Завершена" => ("bg-dark", "bi-check2-all"),
                                        _ => ("bg-secondary", "bi-question")
                                    };
                                }
                                <span class="badge @bg badge-status"><i class="bi @icon"></i> @r.RequestStatus</span>
                            </td>
                            <td>
                                <a href="/Requests/Details/@r.RequestID" class="btn btn-sm btn-outline-primary btn-action"><i class="bi bi-eye"></i></a>
                                @if (userType == "Менеджер" || userType == "Оператор" ||
                                    (userType == "Заказчик" && r.RequestStatus == "Новая заявка") ||
                                    (userType == "Автомеханик"))
                                {
                                    <a href="/Requests/Edit/@r.RequestID" class="btn btn-sm btn-outline-secondary btn-action"><i class="bi bi-pencil"></i></a>
                                }
                                @if (userType == "Менеджер" || userType == "Оператор")
                                {
                                    <form method="post" action="/Requests/Delete/@r.RequestID" style="display:inline" onsubmit="return confirm('Удалить заявку #@r.RequestID?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-action"><i class="bi bi-trash"></i></button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Заявок не найдено</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
