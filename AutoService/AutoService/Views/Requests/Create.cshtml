@model AutoService.Models.Request
@{
    ViewData["Title"] = "Новая заявка";
    var userType = Context.Session.GetString("UserType");
    var clients = ViewBag.Clients as List<AutoService.Models.User> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-plus-circle text-primary"></i> Новая заявка</h3>
    <a href="/Requests" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Назад</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Вид автомобиля</label>
                    <select name="CarType" class="form-select" required>
                        <option value="">Выберите...</option>
                        <option value="Легковая">Легковая</option>
                        <option value="Грузовая">Грузовая</option>
                        <option value="Мотоцикл">Мотоцикл</option>
                        <option value="Автобус">Автобус</option>
                        <option value="Спецтехника">Спецтехника</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Модель автомобиля</label>
                    <input type="text" name="CarModel" class="form-control" placeholder="Например: Toyota Camry" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Описание проблемы</label>
                    <textarea name="ProblemDescription" class="form-control" rows="4" placeholder="Опишите неисправность подробно..." required></textarea>
                </div>
                @if (userType == "Оператор" || userType == "Менеджер")
                {
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Клиент</label>
                        <select name="ClientID" class="form-select" required>
                            <option value="">Выберите клиента...</option>
                            @foreach (var c in clients)
                            {
                                <option value="@c.UserID">@c.FIO (@c.Phone)</option>
                            }
                        </select>
                    </div>
                }
                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg"></i> Создать заявку</button>
                </div>
            </div>
        </form>
    </div>
</div>
