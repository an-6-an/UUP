@{
    ViewData["Title"] = "Импорт данных";
}

<h3 class="fw-bold mb-4"><i class="bi bi-upload text-primary"></i> Импорт данных из файлов</h3>

@if (!string.IsNullOrEmpty(ViewBag.Error as string))
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}
@if (!string.IsNullOrEmpty(ViewBag.Success as string))
{
    <div class="alert alert-success">@ViewBag.Success</div>
}
@if (ViewBag.Errors is List<string> errs && errs.Any())
{
    <div class="alert alert-warning">
        <strong>Предупреждения:</strong>
        <ul class="mb-0 mt-1">
            @foreach (var e in errs) { <li>@e</li> }
        </ul>
    </div>
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header fw-semibold"><i class="bi bi-people"></i> Пользователи</div>
            <div class="card-body">
                <p class="text-muted small">Формат: userID;fio;phone;login;password;type</p>
                <form method="post" action="/Import/ImportUsers" enctype="multipart/form-data">
                    <input type="file" name="file" accept=".txt,.csv" class="form-control mb-3" required />
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-upload"></i> Импортировать</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header fw-semibold"><i class="bi bi-clipboard-check"></i> Заявки</div>
            <div class="card-body">
                <p class="text-muted small">Формат: requestID;startDate;carType;carModel;problemDescription;requestStatus;completionDate;repairParts;masterID;clientID</p>
                <form method="post" action="/Import/ImportRequests" enctype="multipart/form-data">
                    <input type="file" name="file" accept=".txt,.csv" class="form-control mb-3" required />
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-upload"></i> Импортировать</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header fw-semibold"><i class="bi bi-chat-dots"></i> Комментарии</div>
            <div class="card-body">
                <p class="text-muted small">Формат: commentID;message;masterID;requestID</p>
                <form method="post" action="/Import/ImportComments" enctype="multipart/form-data">
                    <input type="file" name="file" accept=".txt,.csv" class="form-control mb-3" required />
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-upload"></i> Импортировать</button>
                </form>
            </div>
        </div>
    </div>
</div>
